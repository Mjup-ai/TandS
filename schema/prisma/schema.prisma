// SES マッチングシステム（コアラ超え版） Prisma スキーマ
// 名寄せ・商流前提のデータモデル

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== 原本系（監査・再解析） ==========

model RawEmail {
  id        String   @id @default(cuid())
  messageId String?  @unique
  receivedAt DateTime
  fromAddr  String
  toAddr    String?
  subject   String?
  bodyText  String?
  bodyHtml  String?
  classification String?  // project | talent | mixed | other
  processingStatus String @default("pending") // pending | extracted | normalized | resolved | error
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  attachments RawAttachment[]
  links       RawLink[]
  ingestEvents IngestEvent[]
  projectOffers ProjectOffer[]
  talentOffers  TalentOffer[]
}

model RawAttachment {
  id          String   @id @default(cuid())
  rawEmailId  String
  rawEmail    RawEmail @relation(fields: [rawEmailId], references: [id])
  filename    String?
  mimeType    String?
  storageKey  String   // 実体の保存先キー
  contentHash String?  // SHA-256。名寄せの「同一ファイル」判定用
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
}

model RawLink {
  id         String   @id @default(cuid())
  rawEmailId String
  rawEmail   RawEmail @relation(fields: [rawEmailId], references: [id])
  url        String
  linkType   String?  // skill_sheet | other
  createdAt  DateTime @default(now())
  deletedAt DateTime?
}

model IngestEvent {
  id         String   @id @default(cuid())
  rawEmailId String
  rawEmail   RawEmail @relation(fields: [rawEmailId], references: [id])
  eventType  String   // classified | extracted | normalized | resolved
  payload    String?  // JSON
  createdAt  DateTime @default(now())
}

// ========== 辞書・マスタ ==========

model Company {
  id   String @id @default(cuid())
  name String
  projects Project[]
}

model Partner {
  id   String @id @default(cuid())
  name String
  projectOffers ProjectOffer[]
  talentOffers  TalentOffer[]
}

model Skill {
  id       String @id @default(cuid())
  code     String @unique  // 正規化コード（JAVA, JAVASCRIPT, REACT）
  name     String
  category String?
  aliases  SkillAlias[]
}

model SkillAlias {
  id      String @id @default(cuid())
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id])
  alias   String
}

model SkillUpdateLog {
  id         String   @id @default(cuid())
  skillId    String?
  action     String   // add | update | delete | alias_add
  oldValue   String?  // JSON or 要約
  newValue   String?  // JSON or 要約
  updatedAt  DateTime @default(now())
  updatedBy  String?
}

model Station {
  id   String @id @default(cuid())
  code String @unique
  name String
}

model EmploymentType {
  id   String @id @default(cuid())
  code String @unique
  name String
}

// ========== 台帳の本体 ==========

model Project {
  id         String   @id @default(cuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  canonicalName String?  // 名寄せ後の案件名
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  offers     ProjectOffer[]
}

model Talent {
  id       String   @id @default(cuid())
  canonicalName String?  // 名寄せ後の表示名（任意）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  offers   TalentOffer[]
}

// ========== オファー（商流・条件の違い） ==========

model ProjectOffer {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id])
  rawEmailId  String?
  rawEmail    RawEmail? @relation(fields: [rawEmailId], references: [id])

  priceMin    Float?
  priceMax    Float?
  paymentTerms String?
  supplyChainDepth Int?   // 1=一次, 2=二次...
  interviewCount   Int?
  requiredSkillIds String?  // JSON array of skill IDs
  optionalSkillIds String?
  workLocation     String?
  remoteOk         Boolean?
  availability     String?   // 週5等
  startPeriod      String?
  duration         String?
  conditions       String?   // JSON（個人不可・年齢等）
  confidenceFlags  String?   // JSON（要確認項目）
  extractedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  matches Match[]
}

model TalentOffer {
  id          String   @id @default(cuid())
  talentId    String
  talent      Talent   @relation(fields: [talentId], references: [id])
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id])
  rawEmailId  String?
  rawEmail    RawEmail? @relation(fields: [rawEmailId], references: [id])

  hopePriceMin Float?
  hopePriceMax Float?
  age         Int?
  employmentTypeId String?
  nearestStationId String?
  workLocationPreference String?
  skillIdsWithYears String?  // JSON: [{ skillId, years, lastUsed }]
  availability String?
  startAvailableDate String?
  skillSheetUrl String?
  skillSheetAttachmentId String?
  confidenceFlags String?
  extractedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matches Match[]
}

// ========== マッチ・進捗 ==========

model Match {
  id              String   @id @default(cuid())
  projectOfferId  String
  projectOffer    ProjectOffer @relation(fields: [projectOfferId], references: [id])
  talentOfferId   String
  talentOffer     TalentOffer  @relation(fields: [talentOfferId], references: [id])
  score           Int?     // 0-100
  scoreBreakdown  String?  // JSON
  isRecommended   Boolean  @default(false)  // score >= 70
  hardFilterFailed Boolean @default(false)
  exclusionReason String?
  recommendationReasons String?  // JSON array (3点)
  attentionPoint  String?
  confirmationQuestions String?  // JSON array (2-3点)
  emailDraft      String?
  callMemo        String?
  createdAt       DateTime @default(now())

  // 評価ループ：採用/見送りを記録し重み調整に利用
  outcome       String?   // pending | accepted | rejected
  outcomeReason String?   // 見送り理由コード
  outcomeNotes  String?   // 自由メモ
  outcomeAt     DateTime?
  outcomeBy     String?

  pipeline Pipeline[]
}

model Pipeline {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  status    String   // proposed | interview | offered | closed_won | closed_lost
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // view | confirm | propose | ...
  targetType String   // match | talent_offer | project_offer | ...
  targetId   String
  payload    String?  // JSON
  createdAt  DateTime @default(now())
}
