DATABASE_URL="file:./prisma/dev.db"
PORT=4000

# Google OAuth (Web app)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:4000/api/google/oauth2/callback"

# Gmail import
GMAIL_IMPORT_ACCOUNT="" # e.g. mjup-forward@example.com
GMAIL_IMPORT_POLL_SEC=60
GMAIL_IMPORT_LOOKBACK_DAYS=7

# OpenAI (AI抽出)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini" # or gpt-4.1

# Mission Control MVP
MISSION_CONTROL_PASSWORD=""
DATA_MODE="mock" # mock|csv|db
FRONTEND_ORIGIN="http://localhost:3000" # optional (enables CORS w/ credentials)

# Optional: Discord webhook URL for persona-style posting (シキ/ツムギ/…)
DISCORD_WEBHOOK_URL=""
